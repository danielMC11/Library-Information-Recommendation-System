sual  atextobtxt2rdacontent  asin mediaciónbn2rdamedia  avolumenbnc2rdacarrier  aLos cladóceros por su papel trófico en la dinámica de los ecosistemas acuáticos han sido investigados como alimento vivo en acuicultura, son candidatos viables por su talla, rapido desarrollo, temprana reproducción, alta tasa de multiplicación, considerable valor nutricional y fácil mantenimiento y cultivo.07aCLADOCERO9141880.07aLARVICULTURA939688.07aLARVICULTURA939688.0 tRevista Mvz CordobadMonteria: Universidad de CordobagVol.6, No.2, (2002). -- p 102 - 110x0122 - 0268  2ddccAS  c34066d3406601102npd a2200301 i 450000100070000000500170000700700030002400800410002704000230006804100080009108200120009910000360011124501530014726400810030030000170038133600270039833700230042533800320044849000460048050400270052665000440055365000590059765000620065670000440071876500080076294200130077099900170078303822720251030133957.0zu150107s2012    ck##################eng#d  aCO-ViULLerdabspa  aeng04aFb21901 aVásquez Torres, Walter940239.00aEffect of Dietary Carbohydrates and Lipids on Growth in Cachama  (Piaractus Brachypomus) /cWalter Vásquez Torres; José Alfredo Arias Castellanos. 1aVillavicencio :bUniversidad de los Llanos. Instituto de Acuicultura,c2012.  a9p :b: tbs.  aotherbxxx2rdacontent  aotherbx2rdamedia  aunspecifiedbzu2rdacarrier 0aAquaculture Research Vol.43 No.129143496  aIncluye Bibliografía.02aPECES DE AGUA DULCExNUTRICION9143497.02aCACHAMA (PIARACTUS BRACHYPOMUS)xALIMENTACION9143498.02aCACHAMA (PIARACTUS BRACHYPOMUS)xINVESTIGACIONES9143499.1 aArias Castellanos, José Alfredo93345.08tEng  2ddccFLL  c34745d3474501336npd a2200313 i 4500001000700000005001700007007000300024008004100027020001900068040002300087082001200110100005000122110007900172245008600251264005500337300000900392336002700401337002300428338003200451490009000483650008500573650008600658650008700744700004400831765000800875942001300883