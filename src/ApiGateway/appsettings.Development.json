{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Jwt": {
    "Key": "THIS_IS_A_DEMO_KEY_CHANGE_IT_123456789",
    "Issuer": "Auth",
    "Audience": "AuthUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-service": {
        "ClusterId": "auth-service",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "catalog-service": {
        "ClusterId": "catalog-service",
        "Match": {
          "Path": "/api/catalog/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/catalog/{**catch-all}" }
        ]
      },
      "interaction-service": {
        "ClusterId": "interaction-service",
        "Match": {
          "Path": "/api/interaction/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/interaction/{**catch-all}" }
        ]
      },
      "recommendation-service": {
        "ClusterId": "recommendation-service",
        "Match": {
          "Path": "/api/recommendation/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/api/recommendation/{**catch-all}" }
        ]
      },
      "swagger-auth": {
        "ClusterId": "auth-service",
        "Match": {
          "Path": "/swagger/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "swagger-catalog": {
        "ClusterId": "catalog-service",
        "Match": {
          "Path": "/swagger/catalog/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "swagger-interaction": {
        "ClusterId": "interaction-service",
        "Match": {
          "Path": "/swagger/interaction/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      },
      "swagger-recommendation": {
        "ClusterId": "recommendation-service",
        "Match": {
          "Path": "/swagger/recommendation/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "/swagger/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "auth-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5132/"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Timeout": "00:00:10",
            "CheckNewConnection": false
          }
        }
      },
      "catalog-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5281/"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Timeout": "00:00:10",
            "CheckNewConnection": false
          }
        }
      },
      "interaction-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5144/"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Timeout": "00:00:10",
            "CheckNewConnection": false
          }
        }
      },
      "recommendation-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5221/"
          }
        },
        "HealthCheck": {
          "Passive": {
            "Enabled": true,
            "Timeout": "00:00:10",
            "CheckNewConnection": false
          }
        }
      }
    }
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "Window": "00:01:00",
    "QueueProcessingOrder": "OldestFirst",
    "QueueLimit": 0
  }
}
