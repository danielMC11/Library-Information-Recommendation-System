{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "RecommendationDb": "Host=rate_limit_postgres;Port=5432;Database=rate_limit_db;Username=postgres;Password=secret-postgres"
  },
  "Gemini": {
    "ApiKey": ""
  },
  "RabbitMQ": {
    "HostName": "rabbitmq",
    "Port": 5672,
    "UserName": "guest",
    "Password": "guest",
    "VirtualHost": "/",
    "Exchanges": {
      "Auth": "auth.exchange",
      "Catalog": "catalog.exchange",
      "Interaction": "interaction.exchange"
    },
    "Events": {
      "StudentRegistered": {
        "Queue": "recommendation.student.embedding.generator.queue",
        "RoutingKey": "student.registered.routing.key"
      },
      "BooksUploaded": {
        "Queue": "recommendation.books.embeddings.generator.queue",
        "RoutingKey": "books.uploaded.routing.key"
      },
      "StudentInteractionsAccumulated": {
        "Queue": "recommendation.user.recommendations.generator.queue",
        "RoutingKey": "user.interactions.accumulated.routing.key"
      }
    }
  },
  "StudentVector": {
    "Alpha": 0.4
  },
  "RateLimit": {
    "MaxRpm": 50,
    "MaxTpm": 10000,
    "MaxRpd": 200
  },
  "Qdrant": {
    "Url": "http://qdrant:6333"
  },
  "Jwt": {
    "Key": "THIS_IS_A_DEMO_KEY_CHANGE_IT_123456789",
    "Issuer": "MiniIdentityApi",
    "Audience": "MiniIdentityApiUsers"
  },
  "CatalogService": {
    "Url": "http://localhost:5281"
  }
}